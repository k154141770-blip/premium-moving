<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>프리미엄 운송 견적</title></head>
<body style="font-family:sans-serif; padding:20px;">
    <h2>🚚 프리미엄 가전/가구 견적</h2>
    <input type="text" id="item" placeholder="예: 75인치 TV" style="width:100%; padding:10px; margin-bottom:10px;">
    <button onclick="sendOrder()" style="width:100%; padding:10px; background:#005088; color:white; border:none;">견적 보내기</button>
    <script>
        function sendOrder() {
            const item = document.getElementById('item').value;
            fetch('/api/order', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({item: item, price: '180,000원'})
            }).then(() => alert('견적이 전송되었습니다!'));
        }
    </script>
</body>
</html>

<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>기사님 오더 보드</title></head>
<body style="font-family:sans-serif; padding:20px;">
    <h2>📲 실시간 오더 목록 (100명 동시 접속)</h2>
    <div id="order-list">
        {% for order in orders %}
        <div style="border:1px solid #ddd; padding:15px; margin-bottom:10px; border-radius:10px;">
            <h3>📦 {{ order.item }}</h3>
            <p>비용: {{ order.price }} | 상태: <strong>{{ order.status }}</strong></p>
            {% if order.status == '대기중' %}
            <button onclick="accept({{ order.id }})" style="padding:10px 20px; background:#11caa0; color:white; border:none; border-radius:5px;">먼저 잡기(수락)</button>
            {% endif %}
        </div>
        {% endfor %}
    </div>
    <script>
        function accept(id) {
            fetch('/api/accept/' + id, {method: 'POST'})
            .then(res => res.json())
            .then(data => {
                if(data.status === 'success') { alert('배차 성공! 고객 정보를 확인하세요.'); location.reload(); }
                else { alert(data.message); location.reload(); }
            });
        }
    </script>
</body>
</html>